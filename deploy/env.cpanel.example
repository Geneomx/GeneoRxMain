# Copy to /home/genecisu/repositories/GeneoRxMain/.env on the server (never commit .env to git).
# Replace placeholders with real values from cPanel MySQL and your dashboards.

APP_NAME=GeneoRx
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://geneorx.com

FRONTEND_URL=https://geneorx.com
CORS_ALLOWED_ORIGINS=https://geneorx.com
SANCTUM_STATEFUL_DOMAINS=geneorx.com,www.geneorx.com

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=genecisu_geneorx
DB_USERNAME=genecisu_dbuser
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.geneorx.com

CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=resend
MAIL_FROM_ADDRESS=noreply@geneorx.com
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=re_CHANGE_ME

STRIPE_KEY=pk_live_CHANGE_ME
STRIPE_SECRET=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PLUS_PRICE_ID=price_CHANGE_ME

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://geneorx.com/auth/google/callback

APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=https://geneorx.com/auth/apple/callback
