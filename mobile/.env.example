# GeneoRx Mobile   Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
# The .env file is gitignored and should never be committed.
#
# For local development, use your machine's LAN IP address so a physical
# iPhone/Android device on the same Wi-Fi can reach the Laravel backend.
# Find your IP: run `ipconfig` (Windows) or `ifconfig` (Mac/Linux).

# Base URL of the Laravel API (no trailing slash)
GENEORX_API_URL=http://192.168.1.x:8000/api
