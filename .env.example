APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Public base URL of this Laravel app (https in production, behind TLS)
APP_URL=http://127.0.0.1:8000
# Web SPA / site origin (Vite, etc.) for documentation and CORS. Not used by the native app.
FRONTEND_URL=http://127.0.0.1:8000
# Comma-separated browser origins for /api CORS. Use a single * only for local dev. In production
# list your web app origins, e.g. https://app.example.com,https://expo.example.com
CORS_ALLOWED_ORIGINS=
# Optional regex patterns, comma-separated
CORS_ALLOWED_ORIGIN_PATTERNS=
# Set true for a cross-origin browser SPA that sends cookies; never combine with CORS * origin.
CORS_SUPPORTS_CREDENTIALS=false
# Comma hosts for Sanctum "stateful" cookie auth (add your real domain in production)
SANCTUM_STATEFUL_DOMAINS=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail   use MAIL_MAILER=log locally, switch to resend in production
# 1. Get your API key at https://resend.com/api-keys
# 2. Verify your sender domain (noreply@geneorx.com) in Resend dashboard
# 3. Set MAIL_MAILER=resend and add RESEND_KEY below
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@geneorx.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe billing (web checkout for Plus plan)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLUS_PRICE_ID=

# ── Google OAuth ───────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials
# 2. Create OAuth 2.0 client (Web application), add redirect URI: APP_URL/auth/google/callback
# 3. Create separate clients for iOS app and Android app (or use Web client for both via expo-auth-session)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=        # OAuth client of type iOS (no secret needed)
GOOGLE_ANDROID_CLIENT_ID=    # OAuth client of type Android

# ── Apple Sign In ──────────────────────────────────────────────────────────
# See docs/apple-setup.md for full instructions.
# IMPORTANT: APPLE_CLIENT_SECRET is a signed JWT you generate once every 6 months.
# Run: php artisan geneorx:generate-apple-secret  to regenerate it.
APPLE_CLIENT_ID=             # Services ID (for web), e.g. com.geneorx.web
APPLE_CLIENT_SECRET=         # Signed JWT client secret
APPLE_BUNDLE_ID=com.geneorx.app  # iOS bundle ID (verify mobile tokens)
APPLE_KEY_ID=                # 10-char Key ID from Apple Developer
APPLE_TEAM_ID=               # 10-char Team ID from Apple Developer

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Google Gemini (optional — AI summary on mobile Summary step)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
