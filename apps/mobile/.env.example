# Base URL of your Laravel app (no trailing slash). Production must use https.
# Physical device: your PC's LAN address, e.g. http://192.168.1.10:8000
# Android emulator: http://10.0.2.2:8000
EXPO_PUBLIC_API_URL=http://127.0.0.1:8000
#
# EAS / store builds: set EXPO_PUBLIC_API_URL in the Expo project (EAS environment variables) or
# eas.json under build.<profile>.env so release builds do not use localhost. Run: npx eas secret:create
