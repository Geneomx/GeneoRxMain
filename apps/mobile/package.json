{
  "name": "geneorx-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "prestart": "node scripts/ensure-assets.cjs",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "postinstall": "node scripts/ensure-assets.cjs",
    "eas:init": "eas init",
    "eas:build:ios:preview": "eas build -p ios --profile preview",
    "eas:build:android:preview": "eas build -p android --profile preview",
    "eas:build:ios": "eas build -p ios --profile production",
    "eas:build:android": "eas build -p android --profile production"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-clipboard": "~7.0.0",
    "expo-constants": "~17.0.8",
    "expo-file-system": "~18.0.0",
    "expo-linking": "~7.0.0",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.0",
    "expo-sharing": "~13.0.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.0",
    "babel-preset-expo": "~12.0.0",
    "eas-cli": "^16.0.0",
    "typescript": "~5.3.0"
  }
}
